{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "QuipForm",
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://quipform.com/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://quipform.com/dashboard?view=developer"
    }
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "authentication",
          "rate-limits"
        ]
      },
      {
        "group": "API Reference",
        "pages": [
          "api-reference/forms/list",
          "api-reference/forms/create",
          "api-reference/forms/get",
          "api-reference/forms/update",
          "api-reference/submissions/list"
        ]
      },
      {
        "group": "MCP Server",
        "pages": [
          "mcp/overview"
        ]
      }
    ]
  },
  "api": {
    "baseUrl": "https://quipform.com/api/v1",
    "auth": {
      "method": "bearer"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/quipform"
    }
  }
}